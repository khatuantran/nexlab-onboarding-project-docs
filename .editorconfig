# EditorConfig — baseline cross-editor settings.
# Prettier + ESLint handle JS/TS; .editorconfig covers everything else (md, yml, sh, dockerfile).
# Spec: https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
# Trailing whitespace in markdown has meaning (hard line break).
trim_trailing_whitespace = false
max_line_length = off

[Makefile]
indent_style = tab

[*.{sh,bash}]
indent_size = 2
