# Copy to infra/docker/.env and tweak only if host ports are taken.
# Compose auto-loads this file because project-directory defaults to
# the directory of docker-compose.yml (i.e. this folder).
# See docs/SETUP.md §4.

POSTGRES_USER=dev
POSTGRES_PASSWORD=dev
POSTGRES_DB=onboardingdb
POSTGRES_PORT=5432
REDIS_PORT=6379
