{
  "name": "@onboarding/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "(lsof -ti:3001 | xargs kill -TERM 2>/dev/null || true) && tsx watch src/index.ts",
    "build": "tsc --build tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:check": "drizzle-kit check",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@onboarding/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "connect-redis": "^8.0.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.36.4",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "file-type": "^22.0.1",
    "ioredis": "^5.4.2",
    "multer": "^2.1.1",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.1",
    "@types/multer": "^2.1.0",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "^0.30.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2"
  }
}
