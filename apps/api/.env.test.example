# Copy to apps/api/.env.test (gitignored).
# Loaded as an overlay on top of apps/api/.env when APP_ENV=test.
# Only override the keys that must differ from dev — DATABASE_URL is
# the main one so vitest + Playwright work against onboardingdb_test
# instead of the dev database.
#
# See docs/SETUP.md §Test database isolation.

# Postgres — same host/port as dev, but a dedicated `_test` database.
# Created by docker-compose init script on first volume create, or via
# `pnpm db:create:test` for existing volumes.
DATABASE_URL=postgresql://dev:dev@localhost:5433/onboardingdb_test
