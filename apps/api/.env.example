# Copy to apps/api/.env (gitignored).
# Loaded by `import "dotenv/config"` at every API entrypoint (dev server,
# drizzle CLI, seed, vitest).
# See docs/SETUP.md §3.

API_PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# Postgres — host/port/user/pass/db must match infra/docker/.env.
# Production (Fly.io) uses Neon pooled URL:
#   postgresql://<user>:<pass>@ep-xxx-pooler.<region>.aws.neon.tech/<db>?sslmode=require
# The pg driver respects sslmode=require; src/db.ts also forces ssl when NODE_ENV=production.
DATABASE_URL=postgresql://dev:dev@localhost:5432/onboardingdb

# Redis — session store + rate limit counter.
# Production (Upstash) uses TLS:
#   rediss://default:<token>@<endpoint>.upstash.io:6379
# ioredis auto-detects TLS from the rediss:// scheme.
REDIS_URL=redis://localhost:6379

# CORS allowlist (comma-separated). Production (Netlify) example:
#   CORS_ORIGIN=https://<netlify-slug>.netlify.app
# Dev default lets the Vite server (5173) hit the API directly.
CORS_ORIGIN=http://localhost:5173

# Session / cookie
SESSION_SECRET=change-me-to-random-long-string
SESSION_COOKIE_NAME=sid
# Set to true in production only (requires HTTPS).
COOKIE_SECURE=false
# Session TTL in seconds. 7 days sliding by default.
SESSION_TTL_SECONDS=604800

# Uploads (FR-UPLOAD-001)
# UPLOAD_DIR is legacy from the pre-CR-004 Fly volume path. Kept as a
# fallback so the magic-byte sniff buffer + temp ops still have a path
# on disk during the request lifecycle. After CR-004 Phase 2 (Cloudinary)
# new uploads never persist locally.
UPLOAD_DIR=./data/uploads
# Max upload size in bytes (5 MiB default).
UPLOAD_MAX_BYTES=5242880

# Cloudinary (CR-004 Phase 2 / FR-UPLOAD-001). Format:
#   cloudinary://<api_key>:<api_secret>@<cloud_name>
# In prod: set as Fly secret. Empty in dev keeps boot working; the
# upload route returns 503 SERVICE_UNAVAILABLE until creds arrive.
CLOUDINARY_URL=
