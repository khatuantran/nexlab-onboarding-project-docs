# Copy to apps/api/.env.local (gitignored).
# Loaded by `import "dotenv/config"` at every API entrypoint (dev server,
# drizzle CLI, seed, vitest).
# See docs/SETUP.md §3.

API_PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# Postgres — host/port/user/pass/db must match infra/docker/.env.
DATABASE_URL=postgresql://dev:dev@localhost:5432/onboardingdb

# Redis — session store + rate limit counter.
REDIS_URL=redis://localhost:6379

# Session / cookie
SESSION_SECRET=change-me-to-random-long-string
SESSION_COOKIE_NAME=sid
# Set to true in production only (requires HTTPS).
COOKIE_SECURE=false
# Session TTL in seconds. 7 days sliding by default.
SESSION_TTL_SECONDS=604800

# Uploads (FR-UPLOAD-001)
UPLOAD_DIR=./data/uploads
# Max upload size in bytes (5 MiB default).
UPLOAD_MAX_BYTES=5242880
