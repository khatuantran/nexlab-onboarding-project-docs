# Copy to apps/web/.env.local (gitignored).
# Vite auto-loads this file during `vite dev` / `vite build`.
# Only VITE_* variables are exposed to the browser bundle.
# See docs/SETUP.md §3.

# Base URL the web app uses to call the API.
VITE_API_BASE_URL=http://localhost:3001/api/v1

# Origin allowed by API CORS (API reads this from apps/api/.env.local).
VITE_APP_ORIGIN=http://localhost:5173
