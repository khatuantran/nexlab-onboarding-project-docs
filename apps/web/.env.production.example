# apps/web/.env.production
# Netlify reads this at build time. Copy to apps/web/.env.production
# (gitignored) for local prod build, or set the same key in Netlify
# Site settings → Build & deploy → Environment variables for deployed builds.
#
# Build settings live in repo-root netlify.toml. See docs/RUNBOOK.md §1.3.

# BE API base URL — Fly.io app URL (no trailing slash).
VITE_API_BASE_URL=https://onboarding-api-cool-waterfall-8568.fly.dev/api/v1
