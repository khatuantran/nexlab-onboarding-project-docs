# apps/web/.env.production
# Cloudflare Pages reads this at build time. Copy to apps/web/.env.production
# (gitignored) for local prod build, or set the same key in Cloudflare
# Pages → Settings → Environment variables for deployed builds.
#
# See docs/RUNBOOK.md §Cloudflare Pages.

# BE API base URL — Fly.io app URL (no trailing slash).
VITE_API_BASE_URL=https://onboarding-api.fly.dev/api/v1
