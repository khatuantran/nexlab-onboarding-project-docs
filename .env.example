# Copy to .env.local (gitignored) and fill in values.
# See docs/SETUP.md §3 for details.

# ===== Web =====
# Base URL that the web app uses to call the API.
VITE_API_BASE_URL=http://localhost:3001/api/v1

# Origin allowed by CORS (API reads this).
VITE_APP_ORIGIN=http://localhost:5173

# ===== API =====
API_PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# Postgres connection string (host, port, user, pass, db must match docker-compose.yml).
DATABASE_URL=postgresql://dev:dev@localhost:5432/onboardingdb

# Redis connection URL (used for session store + rate limit counter).
REDIS_URL=redis://localhost:6379

# Session / cookie
SESSION_SECRET=change-me-to-random-long-string
SESSION_COOKIE_NAME=sid
# Set to true in production only (requires HTTPS).
COOKIE_SECURE=false
# Session TTL in seconds. 7 days sliding by default.
SESSION_TTL_SECONDS=604800

# ===== Uploads (FR-UPLOAD-001) =====
# Directory where uploaded images are stored. In Docker, mount this path as a volume.
UPLOAD_DIR=./data/uploads
# Max upload size in bytes (5 MiB default per FR-UPLOAD-001).
UPLOAD_MAX_BYTES=5242880
