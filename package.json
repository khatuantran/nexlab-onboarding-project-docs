{
  "name": "nexlab-onboarding-project-docs",
  "version": "0.1.0",
  "private": true,
  "description": "Onboarding Doc Portal — internal feature-catalog for dev onboarding",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.9.0 <21",
    "pnpm": ">=9"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "test:e2e": "playwright test",
    "test:infra": "node scripts/test-infra-env.mjs",
    "migrate:env": "./scripts/migrate-env.sh",
    "smoke": "./scripts/smoke.sh",
    "dev": "pnpm -r --parallel run dev",
    "docker:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down",
    "docker:reset": "docker compose -f infra/docker/docker-compose.yml down -v",
    "docker:logs": "docker compose -f infra/docker/docker-compose.yml logs -f",
    "db:generate": "pnpm --filter @onboarding/api db:generate",
    "db:migrate": "pnpm --filter @onboarding/api db:migrate",
    "db:check": "pnpm --filter @onboarding/api db:check",
    "db:seed": "pnpm --filter @onboarding/api db:seed",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,cjs,mjs}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.4.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
